    {
      "id": "repo-standards.installer.add-governance-files",
      "type": "required_text",
      "description": "Standards installer must expose governance-file installation support.",
      "severity": "error",
      "applies_to": [
        "repo-kit"
      ],
      "remediation": "Restore AddGovernanceFiles support in scripts/bootstrap/install_repo_standards.ps1 or adjust the installer contract intentionally.",
      "downstream_override": {
        "allowed": true,
        "mode": "local_policy_overlay",
        "notes": "Downstream repos may keep local policy overlays; standards install copies managed defaults without deleting local files."
      },
      "path": "scripts/bootstrap/install_repo_standards.ps1",
      "contains": [
        "AddGovernanceFiles"
      ]
    },
    {
      "id": "repo-standards.agent-contract.solo-owner-main",
      "type": "required_text",
      "description": "Agent contract must default repo-kit-managed repos to solo-owner direct-main workflow with a local team/PR override.",
      "severity": "error",
      "applies_to": [
        "repo-kit"
      ],
      "remediation": "Restore the solo-owner direct-main workflow wording in AGENTS.md or intentionally update the workflow-mode policy.",
      "downstream_override": {
        "allowed": true,
        "mode": "local_policy_overlay",
        "notes": "Downstream repos may opt into team/PR flow with .repo-kit/workflow_policy.local.json."
      },
      "path": "AGENTS.md",
      "contains": [
        "Default mode is solo-owner direct-main",
        "Commit completed work on `main`",
        ".repo-kit/workflow_policy.local.json"
      ]
    },
    {
      "id": "repo-standards.todo-process.qa-live-coverage-escalation",
      "type": "required_text",
      "description": "TODO process must require QA Live coverage expansion before automatable checks are treated as user-only.",
      "severity": "error",
      "applies_to": [
        "repo-kit"
      ],
      "remediation": "Restore the QA Live coverage-escalation wording in docs/TODO_PROCESS.md or intentionally update the TODO closeout policy.",
      "downstream_override": {
        "allowed": true,
        "mode": "local_policy_overlay",
        "notes": "Downstream repos may add local QA Live prerequisites but should not downgrade automatable checks to user-only by default."
      },
      "path": "docs/TODO_PROCESS.md",
      "contains": [
        "If QA Live cannot currently cover automatable UI, game, Unreal, browser, VM, installer, or runtime behavior",
        "Commit and push any required `qa-live-test-system` change to that repo's `main`",
        "user check is absolutely required"
      ]
    },
    {
      "id": "repo-standards.agent-policy.machine-readable-workflow-mode",
      "type": "required_text",
      "description": "Machine-readable agent policy must expose solo-owner direct-main defaults and QA Live coverage escalation.",
      "severity": "error",
      "applies_to": [
        "repo-kit"
      ],
      "remediation": "Restore repo_workflow_policy and QA Live escalation strings in repo-standards/agents/agent_instruction_compatibility.json.",
      "downstream_override": {
        "allowed": true,
        "mode": "local_policy_overlay",
        "notes": "Downstream repos may overlay workflow mode locally without changing the managed default policy."
      },
      "path": "repo-standards/agents/agent_instruction_compatibility.json",
      "contains": [
        "\"repo_workflow_policy\"",
        "\"default_mode\": \"solo_owner_direct_main\"",
        "add or update the repo-owned QA Live spec/contract or adjacent qa-live-test-system capability"
      ]
    }
  ]
