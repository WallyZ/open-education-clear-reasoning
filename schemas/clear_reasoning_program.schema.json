{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Clear Reasoning Program",
  "type": "object",
  "required": [
    "schema_version",
    "repo_id",
    "program_id",
    "title",
    "license_policy",
    "privacy_boundary",
    "source_canon",
    "mastery_bands",
    "advanced_tracks",
    "practice_labs",
    "course",
    "capstone"
  ],
  "properties": {
    "schema_version": { "const": "open-education-clear-reasoning/program/v1" },
    "repo_id": { "const": "open-education-clear-reasoning" },
    "program_id": { "type": "string", "minLength": 3 },
    "title": { "type": "string", "minLength": 3 },
    "license_policy": {
      "type": "object",
      "required": ["default_content_license", "source_text_boundary"],
      "properties": {
        "default_content_license": { "type": "string" },
        "source_text_boundary": { "type": "string" }
      }
    },
    "privacy_boundary": {
      "type": "object",
      "required": ["contains_learner_private_data", "contains_copyrighted_source_text", "contains_generated_media"],
      "properties": {
        "contains_learner_private_data": { "type": "boolean" },
        "contains_copyrighted_source_text": { "type": "boolean" },
        "contains_generated_media": { "type": "boolean" }
      }
    },
    "source_canon": {
      "type": "array",
      "minItems": 24,
      "items": {
        "type": "object",
        "required": [
          "id",
          "author",
          "work",
          "tradition",
          "integration_stage",
          "source_packet_status",
          "role",
          "recommended_use",
          "use_boundary"
        ],
        "properties": {
          "id": { "type": "string" },
          "author": { "type": "string" },
          "work": { "type": "string" },
          "tradition": { "type": "string" },
          "integration_stage": { "type": "string" },
          "source_packet_status": { "type": "string" },
          "role": { "type": "string" },
          "recommended_use": { "type": "string" },
          "use_boundary": { "type": "string" }
        }
      }
    },
    "mastery_bands": {
      "type": "array",
      "minItems": 5,
      "items": { "type": "string" }
    },
    "advanced_tracks": {
      "type": "array",
      "minItems": 6,
      "items": {
        "type": "object",
        "required": ["id", "title", "source_refs", "outcomes", "labs", "capstone_artifact"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "source_refs": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "outcomes": { "type": "array", "minItems": 2, "items": { "type": "string" } },
          "labs": { "type": "array", "minItems": 2, "items": { "type": "string" } },
          "capstone_artifact": { "type": "string" }
        }
      }
    },
    "practice_labs": {
      "type": "array",
      "minItems": 6,
      "items": {
        "type": "object",
        "required": ["id", "title", "skill_family", "source_refs", "evidence"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "skill_family": { "type": "string" },
          "source_refs": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "evidence": { "type": "string" }
        }
      }
    },
    "course": {
      "type": "object",
      "required": ["id", "title", "estimated_hours", "modules"],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "estimated_hours": { "type": "number", "minimum": 1 },
        "modules": {
          "type": "array",
          "minItems": 12,
          "items": {
            "type": "object",
            "required": ["id", "title", "source_refs", "skills", "practice", "assessment", "performance_pressure"],
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "source_refs": { "type": "array", "minItems": 1, "items": { "type": "string" } },
              "skills": { "type": "array", "minItems": 2, "items": { "type": "string" } },
              "practice": { "type": "array", "minItems": 2, "items": { "type": "string" } },
              "assessment": { "type": "string" },
              "performance_pressure": { "type": "string" }
            }
          }
        }
      }
    },
    "capstone": {
      "type": "object",
      "required": ["id", "required_artifacts", "passing_standard"],
      "properties": {
        "id": { "type": "string" },
        "required_artifacts": { "type": "array", "minItems": 10, "items": { "type": "string" } },
        "passing_standard": { "type": "string" }
      }
    }
  }
}
