{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Civilization Reasoning Framework",
  "type": "object",
  "required": [
    "schema_version",
    "repo_id",
    "primary_spine",
    "purpose",
    "coverage_lanes",
    "required_frameworks",
    "curriculum_matrix_rules",
    "review_gates",
    "build_phases"
  ],
  "properties": {
    "schema_version": { "const": "open-education-clear-reasoning/civilization-framework/v1" },
    "repo_id": { "const": "open-education-clear-reasoning" },
    "primary_spine": { "const": "western-civilization" },
    "purpose": { "type": "string", "minLength": 10 },
    "coverage_lanes": {
      "type": "array",
      "minItems": 8,
      "items": {
        "type": "object",
        "required": [
          "id",
          "priority",
          "civilization",
          "traditions",
          "knowledge_standard",
          "argument_goal",
          "disagreement_norm",
          "authority_structure",
          "transferable_moves",
          "misread_risks",
          "build_status"
        ],
        "properties": {
          "id": { "type": "string", "minLength": 3 },
          "priority": { "type": "string", "enum": ["primary", "comparative"] },
          "civilization": { "type": "string", "minLength": 3 },
          "traditions": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "knowledge_standard": { "type": "string", "minLength": 3 },
          "argument_goal": { "type": "string", "minLength": 3 },
          "disagreement_norm": { "type": "string", "minLength": 3 },
          "authority_structure": { "type": "string", "minLength": 3 },
          "transferable_moves": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "misread_risks": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "build_status": { "type": "string", "minLength": 3 }
        }
      }
    },
    "required_frameworks": { "type": "array", "minItems": 6, "items": { "type": "string" } },
    "curriculum_matrix_rules": { "type": "array", "minItems": 4, "items": { "type": "string" } },
    "review_gates": { "type": "array", "minItems": 5, "items": { "type": "string" } },
    "build_phases": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "object",
        "required": ["id", "summary"],
        "properties": {
          "id": { "type": "string", "minLength": 3 },
          "summary": { "type": "string", "minLength": 3 }
        }
      }
    }
  }
}
